<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find Emergency Services Nearby"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to open in Google Maps"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <GridLayout
            android:id="@+id/gridLayoutServices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:layout_marginBottom="16dp">

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick Search Links"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnNearestHospital"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏥 Nearest Hospital"
            android:backgroundTint="@color/emergency_red"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnNearestPharmacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💊 Nearest Pharmacy"
            android:backgroundTint="@color/info_blue"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnNearestPoliceStation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👮 Nearest Police Station"
            android:backgroundTint="@color/accent"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Note: Google Maps is required for this feature to work properly."
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>

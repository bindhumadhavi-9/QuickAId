<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap on any body part to see injuries and first aid information"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Button to switch to Body Map -->
        <Button
            android:id="@+id/btnOpenBodyMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧍 View Interactive Body Map"
            android:textSize="16sp"
            android:backgroundTint="@color/info_blue"
            android:layout_marginBottom="16dp"/>

        <!-- Front View -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FRONT VIEW"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="400dp"
            android:background="@color/card_background"
            android:padding="16dp">

            <!-- Simple Body Layout using View zones -->
            <!-- Head -->
            <View
                android:id="@+id/zone_head"
                android:layout_width="60dp"
                android:layout_height="70dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>
            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/zone_head"
                android:text="Head"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>

            <!-- Eyes -->
            <View
                android:id="@+id/zone_eyes"
                android:layout_width="60dp"
                android:layout_height="20dp"
                android:layout_below="@id/zone_head"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="2dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Nose -->
            <View
                android:id="@+id/zone_nose"
                android:layout_width="20dp"
                android:layout_height="30dp"
                android:layout_below="@id/zone_eyes"
                android:layout_centerHorizontal="true"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Ears -->
            <View
                android:id="@+id/zone_ears"
                android:layout_width="100dp"
                android:layout_height="30dp"
                android:layout_below="@id/zone_head"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Neck -->
            <View
                android:id="@+id/zone_neck"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_below="@id/zone_nose"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="4dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Chest -->
            <View
                android:id="@+id/zone_chest"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_below="@id/zone_neck"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/zone_chest"
                android:layout_centerHorizontal="true"
                android:text="Chest"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>

            <!-- Abdomen -->
            <View
                android:id="@+id/zone_abdomen"
                android:layout_width="90dp"
                android:layout_height="70dp"
                android:layout_below="@id/zone_chest"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="4dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>
            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/zone_abdomen"
                android:layout_centerHorizontal="true"
                android:text="Abdomen"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>

            <!-- Arms -->
            <View
                android:id="@+id/zone_left_arm"
                android:layout_width="35dp"
                android:layout_height="120dp"
                android:layout_below="@id/zone_neck"
                android:layout_toStartOf="@id/zone_chest"
                android:layout_marginTop="8dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/zone_right_arm"
                android:layout_width="35dp"
                android:layout_height="120dp"
                android:layout_below="@id/zone_neck"
                android:layout_toEndOf="@id/zone_chest"
                android:layout_marginTop="8dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Hands -->
            <View
                android:id="@+id/zone_left_hand"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_below="@id/zone_left_arm"
                android:layout_alignStart="@id/zone_left_arm"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/zone_right_hand"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_below="@id/zone_right_arm"
                android:layout_alignEnd="@id/zone_right_arm"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Legs -->
            <View
                android:id="@+id/zone_left_leg"
                android:layout_width="40dp"
                android:layout_height="100dp"
                android:layout_below="@id/zone_abdomen"
                android:layout_toStartOf="@id/zone_abdomen"
                android:layout_marginTop="8dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/zone_right_leg"
                android:layout_width="40dp"
                android:layout_height="100dp"
                android:layout_below="@id/zone_abdomen"
                android:layout_toEndOf="@id/zone_abdomen"
                android:layout_marginTop="8dp"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Feet -->
            <View
                android:id="@+id/zone_left_foot"
                android:layout_width="40dp"
                android:layout_height="25dp"
                android:layout_below="@id/zone_left_leg"
                android:layout_alignStart="@id/zone_left_leg"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>
            <View
                android:id="@+id/zone_right_foot"
                android:layout_width="40dp"
                android:layout_height="25dp"
                android:layout_below="@id/zone_right_leg"
                android:layout_alignEnd="@id/zone_right_leg"
                android:background="@drawable/oval_body_part"
                android:clickable="true"
                android:focusable="true"/>

        </RelativeLayout>

        <!-- Body Part Quick Access -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick Access"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginBottom="16dp">

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Head" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickHead"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Eyes" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickEyes"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Ears" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickEars"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Neck" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickNeck"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Chest" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickChest"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Arms" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickArms"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Hands" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickHands"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Abdomen" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickAbdomen"/>

            <Button android:layout_width="0dp" android:layout_height="wrap_content"
                android:text="Legs" android:layout_columnWeight="1" android:layout_margin="2dp"
                android:backgroundTint="@color/card_background" android:textSize="12sp"
                android:id="@+id/btnQuickLegs"/>

        </GridLayout>

    </LinearLayout>
</ScrollView>
